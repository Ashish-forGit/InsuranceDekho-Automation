package pages;

import org.openqa.selenium.WebDriver;

import com.aventstack.extentreports.ExtentTest;

import uistore.CarInsuranceNewsPageLocators;
import utils.WebDriverHelper;

public class CarInsuranceNewsPageActions {
	
	WebDriverHelper helper;
	ExtentTest test;

	public CarInsuranceNewsPageActions(WebDriver driver, ExtentTest test) {
		this.test = test;
		helper = new WebDriverHelper(driver);
		helper.addLogAndReportInfo("Home Page Actions initialized successfully.", test);
	}
	
	public void verifyCarInsuranceNewsHeader(String expectedValue) {
		helper.verify(helper.getText(CarInsuranceNewsPageLocators.carInsuranceNewsHeader), expectedValue);
	}
	
	public void clickFirstNewsPresent() {
		helper.clickElement(CarInsuranceNewsPageLocators.firstNewsPresent);
	}
	
	public void verifyNewsWrittenByAuthor(String expectedValue) {
		helper.verify(helper.getText(CarInsuranceNewsPageLocators.writtenByAuthorText), expectedValue);
		
	}

}
