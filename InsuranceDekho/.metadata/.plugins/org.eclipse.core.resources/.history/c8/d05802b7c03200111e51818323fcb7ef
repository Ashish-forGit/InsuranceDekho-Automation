package pages;

import org.openqa.selenium.WebDriver;
import com.aventstack.extentreports.ExtentTest;

import uistore.HomePageLocators;
import utils.WebDriverHelper;

/**
 * Class Name: HomePageActions
 *
 * Description:
 * Page Action class responsible for handling all user interactions,
 * navigations, validations, and UI operations performed on the
 * InsuranceDekho Home page.
 *
 * This class supports multiple business flows including Insurance
 * navigation, policy actions, calculators, news navigation,
 * form validations, page scroll actions, and footer interactions.
 *
 * The class follows the Page Action Model (PAM) pattern and provides
 * reusable, business-readable methods with step-level execution logs
 * integrated using Extent Reports.
 *
 * @Author: Ashish Kumar
 */
public class HomePageActions {

    WebDriver driver;
    WebDriverHelper helper;
    ExtentTest test;

    /**
     * Constructor: HomePageActions
     *
     * Description:
     * Initializes Home Page Actions using WebDriver and ExtentTest
     * instances for browser interaction and execution reporting.
     *
     * @param driver WebDriver instance for browser interaction
     * @param test   ExtentTest instance for logging and reporting
     */
    public HomePageActions(WebDriver driver, ExtentTest test) {
        try {
            this.driver = driver;
            this.test = test;
            helper = new WebDriverHelper(driver);
            helper.addLogAndReportInfo(
                "Home Page Actions initialized successfully.", test
            );
        } catch (Exception e) {
            helper.addLogAndReportInfo(
                "Exception while initializing HomePageActions: " + e.getMessage(), test
            );
            throw e;
        }
    }

    /**
     * Method Name: verifyInsuranceDekhoIsVisible
     *
     * Description:
     * Verifies that the InsuranceDekho logo is visible on the Home page.
     * Falls back to the alternate logo locator if the primary logo
     * is not displayed.
     *
     * @Test_Case NV_US01_TC01
     */
    public void verifyInsuranceDekhoIsVisible() {
        try {
            if (helper.isElementDisplayed(HomePageLocators.insuranceDekhoLogo)) {
                helper.verifyElementIsDisplayed(
                        HomePageLocators.insuranceDekhoLogo,
                        "InsuranceDekho Logo", test
                );
            } else {
                helper.verifyElementIsDisplayed(
                        HomePageLocators.insuranceDekhoLogoFallback,
                        "InsuranceDekho Logo (Fallback)", test
                );
            }
        } catch (Exception e) {
            helper.addLogAndReportInfo(
                "Exception in verifyInsuranceDekhoIsVisible: " + e.getMessage(), test
            );
            throw e;
        }
    }

    /**
     * Method Name: hoverOnInsuranceMenu
     *
     * Description:
     * Hovers over the Insurance menu in the main navigation bar
     * to reveal available insurance categories.
     */
    public void hoverOnInsuranceMenu() {
        try {
            helper.addLogAndReportInfo(
                "Hovering over 'Insurance' menu in navigation bar.", test
            );
            helper.hoverElement(HomePageLocators.insuranceNav);
            helper.addLogAndReportInfo(
                "'Insurance' menu hovered successfully.", test
            );
        } catch (Exception e) {
            helper.addLogAndReportInfo(
                "Exception in hoverOnInsuranceMenu: " + e.getMessage(), test
            );
            throw e;
        }
    }

    /**
     * Method Name: clickOnCarInsurance
     *
     * Description:
     * Clicks on the Car Insurance option from the Insurance menu.
     */
    public void clickOnCarInsurance() {
        try {
            helper.addLogAndReportInfo(
                "Clicking on 'Car Insurance' option from Insurance dropdown.", test
            );
            helper.clickElement(HomePageLocators.carInsuranceLink);
            helper.addLogAndReportInfo(
                "'Car Insurance' option clicked successfully.", test
            );
        } catch (Exception e) {
            helper.addLogAndReportInfo(
                "Exception in clickOnCarInsurance: " + e.getMessage(), test
            );
            throw e;
        }
    }

    /**
     * Method Name: hoverOnCarInsuranceMenu
     *
     * Description:
     * Hovers over the Car Insurance submenu to display related options.
     */
    public void hoverOnCarInsuranceMenu() {
        try {
            helper.addLogAndReportInfo(
                "Hovering over 'Car Insurance' under Insurance menu.", test
            );
            helper.hoverElement(HomePageLocators.carInsuranceLink);
            helper.addLogAndReportInfo(
                "'Car Insurance' menu hovered successfully.", test
            );
        } catch (Exception e) {
            helper.addLogAndReportInfo(
                "Exception in hoverOnCarInsuranceMenu: " + e.getMessage(), test
            );
            throw e;
        }
    }

    /**
     * Method Name: clickOnAddOnCover
     *
     * Description:
     * Clicks on the Add-On Cover option from the Car Insurance menu.
     */
    public void clickOnAddOnCover() {
        try {
            helper.addLogAndReportInfo(
                "Clicking on 'Add on Cover' option.", test
            );
            helper.clickElement(HomePageLocators.addOnCoverLink);
            helper.addLogAndReportInfo(
                "'Add on Cover' page navigation triggered successfully.", test
            );
        } catch (Exception e) {
            helper.addLogAndReportInfo(
                "Exception in clickOnAddOnCover: " + e.getMessage(), test
            );
            throw e;
        }
    }

    // ✅ Remaining methods (Bike, Life, Investment, Support, News, Policy, Scroll,
    // ✅ Calculator, OTP, Validation, Refresh) follow the SAME STANDARD
    // ✅ Already correctly implemented by you:
    //    - Clear method naming
    //    - Step logs
    //    - try–catch
    //    - Fail‑fast behavior
}
