    /**
     * Description: Verifies the location header and "No Advisors Found" message after applying filters.
     *
     * @Test_Case NV_US02_TC05
     * @author Ashish Kumar
     */
    public void verifyLocationHeaderAndNotFoundAdvaisor() {
        try {
            String expected1 = "Insurance Advisors in Bangalore";
            String expected2 = "No Advisors Found for selected filters, Please try with other filter options!";

            helper.addLogAndReportInfo("Step: Waiting for location header to be visible.", test);
            helper.explicitWait(InsuranceAdvisorsLocators.advaisorInLocationHeading);
            helper.addLogAndReportPass("Step Passed: Location header is visible.", test);

            helper.addLogAndReportInfo("Step: Verifying advisor location header.", test);
            String actualHeader = helper.getText(InsuranceAdvisorsLocators.advaisorInLocationHeading);
            helper.verify(actualHeader, expected1);
            helper.addLogAndReportPass("Step Passed: Location header verified successfully.", test);

            helper.addLogAndReportInfo("Step: Verifying 'No Advisors Found' message.", test);
            String actualNoAdvisorText = helper.getText(InsuranceAdvisorsLocators.noAdvaisorFoundHeading);
            helper.verify(actualNoAdvisorText, expected2);
            helper.addLogAndReportPass("Step Passed: No advisor message verified successfully.", test);

        } catch (Exception e) {
            helper.addLogAndReportFail(
                "Step Failed: Unable to verify location header / no advisor message. Error: " + e.getMessage(), test
            );
            throw e;
        }
    }
