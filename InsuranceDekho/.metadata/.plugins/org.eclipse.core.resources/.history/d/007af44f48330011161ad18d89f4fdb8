/**
 * Class Name: InsuranceAdvisorsActions
 *
 * Description: Page Action class responsible for handling all user
 * interactions, validations, and workflows related to the Insurance Advisors
 * module.
 *
 * This includes advisor listing validation, booking home visits, form
 * submission, error handling, location-based filtering, and scheduling visit
 * flows.
 *
 * The class follows the Page Action Model (PAM) pattern and provides
 * business-readable, reusable methods with step-level logging integrated via
 * Extent Reports.
 *
 * @Author: Ashish Kumar
 */
public class InsuranceAdvisorsActions {

	WebDriver driver;
	WebDriverHelper helper;
	ExtentTest test;

	/**
	 * Description: Initializes Insurance Advisors page actions using WebDriver and
	 * ExtentTest instances for browser interaction and execution reporting.
	 *
	 * @Test_Case NV_US07_TC01 - verifyInsuranceAdvisorsBookingHomeVisitSuccess,
	 *            NV_US08_TC01 - verifyInsuranceAdvisorsInvalidMobileValidation,
	 *            NV_US09_TC01 - verifyScheduleHomeVisitWithManualLocationDetails,
	 *            NV_US10_TC01 - verifyAreaFieldRequiredValidationOnScheduleVisit,
	 *            NV_US11_TC01 - verifyAdvisorFilterShowsNoAdvisorsFoundMessage
	 * @param driver WebDriver instance for browser interaction
	 * @param test   ExtentTest instance for logging and reporting
	 * @author Ashish Kumar
	 */
	public InsuranceAdvisorsActions(WebDriver driver, ExtentTest test) {
		try {
			this.driver = driver;
			this.test = test;
			helper = new WebDriverHelper(driver);
			helper.addLogAndReportInfo("Insurance Advisors Page Actions initialized successfully.", test);
		} catch (Exception e) {
			helper.addLogAndReportInfo("Exception while initializing InsuranceAdvisorsActions: " + e.getMessage(),
					test);
			throw e;
		}
	}

	/**
	 * Description: Verifies that the 'Insurance Advisors Found' text is displayed
	 * correctly on the page.
	 *
	 * @Test_Case NV_US07_TC01 - verifyInsuranceAdvisorsBookingHomeVisitSuccess,
	 *            NV_US08_TC01 - verifyInsuranceAdvisorsInvalidMobileValidation
	 * @author Ashish Kumar
	 */
	public void verifyInsuranceAdvisorsFoundText() {
		try {
			String expectedValue = "6 Insurance Advisors found";
			helper.addLogAndReportInfo("Verifying Insurance Advisors found text.", test);

			helper.hoverElement(InsuranceAdvisorsLocators.insuranceAdvisorsFoundText);

			helper.verify(helper.getText(InsuranceAdvisorsLocators.insuranceAdvisorsFoundText), expectedValue);

			helper.addLogAndReportPass("Insurance Advisors found text verified successfully.", test);
		} catch (Exception e) {
			helper.addLogAndReportFail("Exception in verifyInsuranceAdvisorsFoundText: " + e.getMessage(), test);
			throw e;
		}
	}

